{
  "name": "gestao-prime",
  "private": true,
  "scripts": {
    "postinstall": "turbo build --filter=@gestao-prime/shared && npm run prisma:generate --workspace=@gestao-prime/api",
    "dev": "turbo build --filter=@gestao-prime/shared && npm run prisma:generate --workspace=@gestao-prime/api && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "chokidar": "^5.0.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "packageManager": "npm@11.15.0"
}
